generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PayStatus {
  UNPAID
  PAID
  REFUNDED
}

enum ProductType {
  PHYSICAL
  DIGITAL
}

enum BlockType {
  LINK
  GROUP
  IMAGE
  TEXT
  VIDEO
  PHONE
  EMAIL_BLOCK
  MESSENGER
  MAP
  MUSIC
  PODCAST
  FAQ
  REDIRECT
  FEATURED
  EMAIL_CAPTURE
  DIVIDER
  ORDER_FORM
  FLASH_SALE
  WHATSAPP
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  phone        String?   @unique
  email        String?   @unique
  passwordHash String?
  plan         Plan      @default(FREE)
  planExpiresAt DateTime?
  isVerified   Boolean   @default(false)
  isBlocked    Boolean   @default(false)
  role         Role      @default(USER)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  shop            Shop?
  subscriptions   Subscription[]
  tickets         Ticket[]
  adminLogs       AdminLog[]
  blogPosts       BlogPost[]
  notifications   Notification[]
  telegramConfig  TelegramConfig?
  autoReplies     AutoReply[]

  @@index([email])
  @@index([phone])
  @@index([plan])
  @@index([createdAt])
}

// ─── Shop (Bio Page) ─────────────────────────────────────────────────────────

model Shop {
  id           String   @id @default(uuid())
  userId       String   @unique
  slug         String   @unique
  name         String
  bio          String?  @db.VarChar(500)
  avatarUrl    String?
  avatarVideo  String?
  bannerUrl    String?
  bgImageUrl   String?
  bgVideoUrl   String?
  themeId         String   @default("default")
  primaryColor    String   @default("#F97316")
  secondaryColor  String   @default("#ffffff")
  fontFamily      String   @default("Vazirmatn")
  customDomain        String?  @unique
  verificationToken   String?
  verificationStatus  String?  @default("PENDING")
  verifiedAt          DateTime?
  gaId                String?
  metaPixel    String?
  metaTitle    String?
  metaDesc     String?  @db.VarChar(200)
  ogImage      String?
  cardNumber   String?  // شماره کارت برای پرداخت کارت‌به‌کارت
  cardHolder   String?  // نام صاحب کارت
  bankName     String?  // نام بانک
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks           Block[]
  products         Product[]
  orders           Order[]
  analytics        Analytics[]
  coupons          Coupon[]
  abTests          ABTest[]
  contentPlans     ContentPlan[]
  digitalFiles     DigitalFile[]
  courses          Course[]
  appointmentSvcs  AppointmentService[]
  shortLinks       ShortLink[]
  audienceLeads    AudienceLead[]
  affiliateLinks   AffiliateLink[]
  flashSales       FlashSale[]

  @@index([slug])
  @@index([userId])
}

// ─── Block ───────────────────────────────────────────────────────────────────

model Block {
  id            String    @id @default(uuid())
  shopId        String
  type          BlockType
  label         String?
  url           String?
  icon          String?
  data          Json?
  isActive      Boolean   @default(true)
  isFeatured    Boolean   @default(false)
  sortOrder     Int       @default(0)
  scheduleStart DateTime?
  scheduleEnd   DateTime?
  groupId       String?
  clickCount    Int       @default(0)
  createdAt     DateTime  @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, sortOrder])
  @@index([shopId, isActive])
}

// ─── Product ─────────────────────────────────────────────────────────────────

model Product {
  id          String      @id @default(uuid())
  shopId      String
  type        ProductType @default(PHYSICAL)
  name        String
  description String?
  category    String?
  price       BigInt
  images      String[]
  stock       Int         @default(1)
  weight      Int?        // وزن به گرم (برای محاسبه ارسال)
  prepTime    String?     // زمان آماده‌سازی ارسال، مثلاً «۱ تا ۳ روز کاری»
  fileUrl     String?
  isAvailable Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, isAvailable])
}

// ─── Order ───────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(uuid())
  shopId          String
  orderNumber     String      @unique
  customerName    String
  customerPhone   String
  customerAddress String?
  items           Json
  totalPrice      BigInt
  discount        BigInt      @default(0)
  couponCode      String?
  status            OrderStatus @default(PENDING)
  paymentStatus     PayStatus   @default(UNPAID)
  paymentRef        String?
  note              String?
  carrier           String?
  trackingCode      String?
  estimatedDelivery DateTime?
  trackingHistory   Json        @default("[]")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
  @@index([orderNumber])
  @@index([createdAt])
}

// ─── Analytics ───────────────────────────────────────────────────────────────

model Analytics {
  id        String   @id @default(uuid())
  shopId    String
  event     String
  data      Json?
  ip        String?
  userAgent String?
  referer   String?
  country   String?
  city      String?
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, event])
  @@index([shopId, createdAt])
}

// ─── Subscription ────────────────────────────────────────────────────────────

model Subscription {
  id          String   @id @default(uuid())
  userId      String
  plan        Plan
  duration    Int
  price       BigInt
  paymentRef  String?
  startsAt    DateTime @default(now())
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ─── Coupon ──────────────────────────────────────────────────────────────────

model Coupon {
  id          String   @id @default(uuid())
  shopId      String?
  code        String   @unique
  type        String   @default("percent")
  value       Int
  maxUses     Int      @default(-1)
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  shop Shop? @relation(fields: [shopId], references: [id], onDelete: SetNull)

  @@index([code])
}

// ─── Ticket ──────────────────────────────────────────────────────────────────

model Ticket {
  id        String         @id @default(uuid())
  userId    String
  subject   String
  message   String         @db.Text
  status    TicketStatus   @default(OPEN)
  priority  TicketPriority @default(NORMAL)
  assignedTo String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies TicketReply[]

  @@index([userId, status])
  @@index([status, priority])
}

model TicketReply {
  id        String   @id @default(uuid())
  ticketId  String
  authorId  String
  isAdmin   Boolean  @default(false)
  message   String   @db.Text
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

// ─── Admin Log ───────────────────────────────────────────────────────────────

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  target    String?
  data      Json?
  ip        String?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
}

// ─── Site Settings ───────────────────────────────────────────────────────────

model SiteSettings {
  id              String   @id @default("default")
  siteName        String   @default("ویلینک")
  siteDesc        String?
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String   @default("#111827")
  accentColor     String   @default("#F97316")
  adminUsername   String   @default("hamid")
  adminEmail      String   @default("hamid@weelink.com")
  smtpConfig      Json?
  smsConfig       Json?
  paymentConfig   Json?
  socialLinks     Json?
  seoTitle        String?
  seoDesc         String?
  seoKeywords     String?
  maintenanceMode Boolean  @default(false)
  maintenanceMsg  String?
  planPrices      Json?
  customLinks     Json?
  updatedAt       DateTime @updatedAt
}

// ─── Blog Post ───────────────────────────────────────────────────────────────

model BlogPost {
  id          String    @id @default(uuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String    @db.Text
  coverImage  String?
  authorId    String
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  tags        String[]
  viewCount   Int       @default(0)
  seoTitle    String?
  seoDesc     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([isPublished, publishedAt])
}

// ─── Page Content ─────────────────────────────────────────────────────────────

model PageContent {
  id        String   @id
  title     String?
  content   Json
  updatedAt DateTime @updatedAt
}

// ─── Landing Page ─────────────────────────────────────────────────────────────

model LandingPage {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  blocks      Json     @default("[]")
  isPublished Boolean  @default(false)
  seoTitle    String?
  seoDesc     String?
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug, isPublished])
}

// ─── A/B Test ─────────────────────────────────────────────────────────────────

model ABTest {
  id            String   @id @default(uuid())
  shopId        String
  name          String
  variantA      Json     @default("[]")
  variantB      Json     @default("[]")
  trafficSplit  Float    @default(0.5)
  status        String   @default("RUNNING")
  winner        String?
  impressionA   Int      @default(0)
  impressionB   Int      @default(0)
  conversionA   Int      @default(0)
  conversionB   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
}

// ─── Content Plan (تقویم محتوایی) ────────────────────────────────────────────

model ContentPlan {
  id                 String   @id @default(uuid())
  shopId             String
  title              String
  description        String?  @db.Text
  platform           String   @default("instagram")
  contentType        String   @default("post")
  scheduledAt        DateTime
  status             String   @default("PLANNED")
  color              String   @default("#F97316")
  notifyBefore       Int[]    @default([24])
  notifyViaSms       Boolean  @default(false)
  notifyViaEmail     Boolean  @default(false)
  notifyViaTelegram  Boolean  @default(false)
  remindersSent      Int[]    @default([])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, scheduledAt])
  @@index([shopId, status])
}

model TelegramConfig {
  id        String   @id @default(uuid())
  userId    String   @unique
  chatId    String
  username  String?
  botToken  String?  // توکن ربات اختصاصی کاربر (ارسال یادآور از طریق ربات خودش)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id         String    @id @default(uuid())
  title      String
  body       String
  type       String    @default("info")
  targetPlan String?
  userId     String?
  isGlobal   Boolean   @default(true)
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([isGlobal, createdAt])
}

// ─── Digital File ─────────────────────────────────────────────────────────────

model DigitalFile {
  id            String   @id @default(uuid())
  shopId        String
  title         String
  description   String?
  fileUrl       String
  coverUrl      String?
  price         BigInt   @default(0)
  isFree        Boolean  @default(false)
  downloadCount Int      @default(0)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop      Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  purchases DigitalPurchase[]

  @@index([shopId, isActive])
}

model DigitalPurchase {
  id            String      @id @default(uuid())
  fileId        String
  customerEmail String
  customerName  String?
  amountPaid    BigInt      @default(0)
  paymentRef    String?
  paymentStatus PayStatus   @default(UNPAID)
  downloadToken String      @unique @default(uuid())
  downloadedAt  DateTime?
  createdAt     DateTime    @default(now())

  file DigitalFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([downloadToken])
}

// ─── Course ───────────────────────────────────────────────────────────────────

model Course {
  id          String   @id @default(uuid())
  shopId      String
  title       String
  description String?  @db.Text
  coverUrl    String?
  price       BigInt   @default(0)
  isFree      Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop     Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  chapters CourseChapter[]
  enrollments CourseEnrollment[]

  @@index([shopId, isActive])
}

model CourseChapter {
  id        String   @id @default(uuid())
  courseId  String
  title     String
  videoUrl  String?
  fileUrl   String?
  sortOrder Int      @default(0)
  isPreview Boolean  @default(false)
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, sortOrder])
}

model CourseEnrollment {
  id            String    @id @default(uuid())
  courseId      String
  customerEmail String
  customerName  String?
  amountPaid    BigInt    @default(0)
  paymentRef    String?
  paymentStatus PayStatus @default(UNPAID)
  accessToken   String    @unique @default(uuid())
  createdAt     DateTime  @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

// ─── Appointment ──────────────────────────────────────────────────────────────

model AppointmentService {
  id           String   @id @default(uuid())
  shopId       String
  name         String
  description  String?
  durationMins Int      @default(60)
  price        BigInt   @default(0)
  isFree       Boolean  @default(false)
  isActive     Boolean  @default(true)
  color        String   @default("#F97316")
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([shopId, isActive])
}

model Appointment {
  id            String    @id @default(uuid())
  serviceId     String
  customerName  String
  customerPhone String
  customerEmail String?
  date          DateTime
  status        String    @default("PENDING")
  note          String?
  paymentRef    String?
  paymentStatus PayStatus @default(UNPAID)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  service AppointmentService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, date])
  @@index([date])
}

// ─── Short Link ───────────────────────────────────────────────────────────────

model ShortLink {
  id          String   @id @default(uuid())
  shopId      String
  originalUrl String
  shortCode   String   @unique
  title       String?
  clickCount  Int      @default(0)
  isActive    Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([shortCode])
}

// ─── Audience Lead ────────────────────────────────────────────────────────────

model AudienceLead {
  id        String   @id @default(uuid())
  shopId    String
  email     String
  name      String?
  source    String?
  tags      String[]
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, email])
  @@index([shopId, createdAt])
}

// ─── Auto Reply ───────────────────────────────────────────────────────────────

model AutoReply {
  id        String   @id @default(uuid())
  userId    String
  platform  String
  keyword   String
  reply     String   @db.Text
  isActive  Boolean  @default(true)
  triggerCount Int   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform])
}

// ─── Affiliate Link ───────────────────────────────────────────────────────────

model AffiliateLink {
  id          String   @id @default(uuid())
  shopId      String
  title       String
  originalUrl String
  commission  Float    @default(0)
  clickCount  Int      @default(0)
  earnings    BigInt   @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, isActive])
}

// ─── Flash Sale ───────────────────────────────────────────────────────────────

model FlashSale {
  id          String   @id @default(uuid())
  shopId      String
  title       String
  description String?
  originalPrice BigInt
  salePrice   BigInt
  imageUrl    String?
  endsAt      DateTime
  isActive    Boolean  @default(true)
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, isActive])
}
